# ====================================================================
# SYND_GEST - Variables d'Environnement
# ====================================================================
# Fichier exemple pour la configuration des variables d'environnement
# 
# INSTRUCTIONS:
# 1. Copier ce fichier en .env pour le développement local (optionnel)
# 2. Pour Heroku, configurer ces variables via: heroku config:set KEY=value
# 
# IMPORTANT: Ne jamais commiter le fichier .env avec les vraies valeurs !
# ====================================================================

# --------------------------------------------------------------------
# ENVIRONNEMENT
# --------------------------------------------------------------------
# Environnement: development, production
ENVIRONMENT=production

# Mode debug: true, false
DEBUG=false

# --------------------------------------------------------------------
# BASE DE DONNÉES
# --------------------------------------------------------------------
# Pour Heroku, cette variable est automatiquement configurée par ClearDB
# Format: mysql://username:password@hostname/database_name
DATABASE_URL=mysql://root:@localhost/synd_gest

# --------------------------------------------------------------------
# SÉCURITÉ
# --------------------------------------------------------------------
# Clé secrète pour le chiffrement (générer avec: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_change_in_production

# --------------------------------------------------------------------
# EMAIL (SendGrid pour Heroku)
# --------------------------------------------------------------------
# Host SMTP
MAIL_HOST=smtp.sendgrid.net

# Port SMTP
MAIL_PORT=587

# Identifiants SendGrid (ou autre service SMTP)
SENDGRID_USERNAME=apikey
SENDGRID_PASSWORD=your_sendgrid_api_key_here

# Email expéditeur
MAIL_FROM_ADDRESS=noreply@syndgest.fr
MAIL_FROM_NAME=Synd_Gest

# --------------------------------------------------------------------
# HEROKU (détecté automatiquement)
# --------------------------------------------------------------------
# Ces variables sont automatiquement définies par Heroku
# HEROKU_APP_NAME=your-app-name
# DYNO=web.1

# --------------------------------------------------------------------
# CONFIGURATION OPTIONNELLE
# --------------------------------------------------------------------

# Limite de taille d'upload (en Mo)
MAX_UPLOAD_SIZE=10

# Durée de session (en secondes)
SESSION_LIFETIME=7200

# Email admin
ADMIN_EMAIL=admin@syndgest.fr

# Nom de l'application
APP_NAME=Synd_Gest

# --------------------------------------------------------------------
# SERVICES TIERS (optionnel)
# --------------------------------------------------------------------

# API de géolocalisation (optionnel)
# GEOCODING_API_KEY=your_api_key

# Service de stockage cloud (optionnel - AWS S3, etc.)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_BUCKET=your_bucket_name
# AWS_REGION=eu-west-1

# --------------------------------------------------------------------
# NOTES POUR HEROKU
# --------------------------------------------------------------------
# 
# Pour configurer ces variables sur Heroku:
# 
# heroku config:set SECRET_KEY=your_secret_key
# heroku config:set SENDGRID_USERNAME=apikey
# heroku config:set SENDGRID_PASSWORD=your_api_key
# 
# Pour voir les variables configurées:
# heroku config
# 
# Pour ajouter ClearDB MySQL:
# heroku addons:create cleardb:ignite
# 
# Pour ajouter SendGrid:
# heroku addons:create sendgrid:starter
# 
# ====================================================================
