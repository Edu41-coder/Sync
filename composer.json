{
    "name": "synd-gest",
    "description": "Logiciel de Gestion Immobilière et Syndic de Copropriété",
    "version": "1.0.0",
    "keywords": [
        "gestion",
        "immobilier",
        "syndic",
        "copropriete",
        "php"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.0.0",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-gd": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "scripts": {
        "test": "phpunit",
        "post-install-cmd": [
            "@php -r \"copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
